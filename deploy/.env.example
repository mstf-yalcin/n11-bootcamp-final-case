# ====================================================================
# n11 Bootcamp — Environment Variables (Template)
# ====================================================================
# Copy this file as `.env`:
#   cp .env.example .env
#
# All variables have defaults in docker-compose.yml and application.yaml;
# this file is for overrides.
#
# When running inside containers (compose up): use service names
#   (postgres, redis, kafka, elasticsearch, etc.)
# When running on host (mvn spring-boot:run): use localhost
# ====================================================================

# -------------------------------------------------------------
# DATABASE (PostgreSQL)
# -------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=pass123
DB_NAME=postgres
# always → schema.sql/data.sql executed on every start (dev)
# never  → skipped (prod / Flyway / Hibernate ddl-auto)
SQL_INIT_MODE=always

# -------------------------------------------------------------
# REDIS
# -------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=pass123

# -------------------------------------------------------------
# KAFKA
# -------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# -------------------------------------------------------------
# ELASTICSEARCH
# -------------------------------------------------------------
# Between containers: elasticsearch:9200
# From host: localhost:9201 (compose 9201 → container 9200 mapping)
ELASTICSEARCH_URI=http://elasticsearch:9200

# -------------------------------------------------------------
# EUREKA / SERVICE DISCOVERY
# -------------------------------------------------------------
EUREKA_URI=http://discovery-server:8761/eureka

# -------------------------------------------------------------
# APP PROFILE (services: user, product, cart, stock, order, payment, gateway)
# -------------------------------------------------------------
# Environment profile loaded by services from config-server.
# dev  → reads <service>-dev.yml from n11-config
# prod → reads <service>-prod.yml from n11-config
SPRING_PROFILES_ACTIVE=dev

# -------------------------------------------------------------
# SPRING CLOUD CONFIG SERVER (profile selection)
# -------------------------------------------------------------
# config-server's own Spring profile. Decoupled from services'
# SPRING_PROFILES_ACTIVE to avoid env-var collision.
# Internally mapped to SPRING_PROFILES_ACTIVE inside config-server container.
# native → reads local files (n11-config/ directory mounted in)
# git    → pulls from remote repo (CONFIG_REPO_URI required)
CONFIG_PROFILE=native
CONFIG_URI=http://config-server:8888

# For git profile (optional):
# CONFIG_REPO_URI=https://github.com/<user>/xxx-config.git
# CONFIG_REPO_BRANCH=master
# CONFIG_REPO_USERNAME=<github-user>
# CONFIG_REPO_PASSWORD=<github-pat-token>

# -------------------------------------------------------------
# AUTH (JWT)
# -------------------------------------------------------------
USER_SERVICE_URL=http://user-service:9000
JWT_ISSUER=n11-bootcamp
JWT_KEY_ID=n11-key-1
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_MINUTES=1440
# Refresh token HMAC secret — replace with a strong random string
REFRESH_TOKEN_SECRET=n11BootcampRefreshTokenSecret1234!!

# -------------------------------------------------------------
# AUTH COOKIE (refresh token HttpOnly cookie)
# -------------------------------------------------------------
# COOKIE_SECURE:
#   false → works over HTTP (dev / non-HTTPS deploy)
#   true  → HTTPS-only; browser rejects the cookie on HTTP requests (prod)
# COOKIE_SAMESITE:
#   Strict → never sent in cross-site context (full CSRF protection)
#   Lax    → sent on top-level GET navigation; blocked on cross-site AJAX/POST
#   None   → sent cross-site; requires Secure=true (3rd-party widget scenario)
COOKIE_REFRESH_NAME=refreshToken
COOKIE_SECURE=false
COOKIE_SAMESITE=Strict
COOKIE_PATH=/api/v1/auth
# 604800 seconds = 7 days — must match the refresh token lifetime
COOKIE_MAX_AGE=604800

# -------------------------------------------------------------
# CORS
# -------------------------------------------------------------
# Glob pattern, comma-separated list supported: "https://app.foo.com,http://localhost:*"
# Cookie auth requires: allowCredentials=true + explicit origin (wildcard "*" not allowed).
# Frontend baseURL must be listed here, otherwise the browser will not send the cookie.
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*

# -------------------------------------------------------------
# SWAGGER / OPENAPI
# -------------------------------------------------------------
# true  → enabled in dev (via gateway /v3/api-docs)
# false → disabled in prod
SPRINGDOC_ENABLED=true

# -------------------------------------------------------------
# PRODUCT SEARCH ENGINE
# -------------------------------------------------------------
# elastic → product list/search reads from Elasticsearch (default)
# jpa     → fallback, searches PG (when ES infrastructure unavailable)
PRODUCT_SEARCH_ENGINE=elastic

# -------------------------------------------------------------
# CART
# -------------------------------------------------------------
CART_MAX_QUANTITY_PER_ITEM=10

# -------------------------------------------------------------
# STOCK
# -------------------------------------------------------------
STOCK_CACHE_TTL_SECONDS=60
STOCK_LOW_THRESHOLD=10

# -------------------------------------------------------------
# PAYMENT (Iyzico)
# -------------------------------------------------------------
# sandbox    → test environment (default)
# production → real payments (requires real API key/secret)
# mock       → no external API call, in-memory mock
PAYMENT_MODE=mock
IYZICO_API_KEY=sandbox-your-api-key
IYZICO_SECRET_KEY=sandbox-your-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Test card details (used by payment-service Iyzico sandbox)
IYZICO_TEST_CARD_NUMBER=5528790000000008
IYZICO_TEST_CVC=123
IYZICO_TEST_EXP_MONTH=12
IYZICO_TEST_EXP_YEAR=2030
IYZICO_TEST_HOLDER=John Doe

# -------------------------------------------------------------
# OBSERVABILITY (Tracing)
# -------------------------------------------------------------
# Tempo / Jaeger OTLP HTTP endpoint
OTLP_TRACES_ENDPOINT=http://tempo:4318/v1/traces
# Sampling rate between 0.0 - 1.0. Dev: 1.0 (every trace), Prod: 0.05-0.1
TRACING_SAMPLE_RATE=0.1

# -------------------------------------------------------------
# NOTIFICATIONS (Grafana Alertmanager)
# -------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/YYYYY/ZZZZZ

# -------------------------------------------------------------
# GRAFANA (when observability section in docker-compose is uncommented)
# -------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3000

# -------------------------------------------------------------
# CI / IMAGE REGISTRY (for jib remote push)
# -------------------------------------------------------------
IMAGE_REPO=europe-west1-docker.pkg.dev/<gcp-project>/<repo>